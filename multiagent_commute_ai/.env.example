# LLM Configuration
# LLM_PROVIDER=openai   -> uses OPENAI_API_KEY + LLM_MODEL
# LLM_PROVIDER=ollama   -> uses local Ollama (no API key needed)
LLM_PROVIDER=ollama
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024

# Ollama Configuration (download from https://ollama.com)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Mock Mode - set true to test with no LLM at all
LLM_MOCK_MODE=false

# Embedding Model
EMBED_MODEL=sentence-transformers/all-mpnet-base-v2
EMBED_DIMENSION=768

# RAG Configuration
CHUNK_SIZE=100
CHUNK_OVERLAP=20
TOP_K_RETRIEVAL=5
POLICY_DOCS_DIR=data/policies
FAISS_INDEX_PATH=indexes/policy_index.faiss

# ML Configuration
ISOLATION_FOREST_MODEL_PATH=models/isolation_forest.pkl
SHAP_EXPLAINER_PATH=models/shap_explainer.pkl
CONTAMINATION=0.05
N_ESTIMATORS=100
ANOMALY_THRESHOLD=-0.1

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
