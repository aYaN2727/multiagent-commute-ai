{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run FastAPI Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Retrain Anomaly Model",
            "type": "debugpy",
            "request": "launch",
            "module": "ml.train_isolation_forest",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Rebuild RAG Index",
            "type": "debugpy",
            "request": "launch",
            "module": "rag.ingestion",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Adapt IEEE-CIS Dataset",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/data/adapt_ieee_cis.py",
            "args": ["--sample", "200000"],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Run Tests",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_pipeline.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
